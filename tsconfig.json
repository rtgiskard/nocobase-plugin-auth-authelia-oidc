{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node", "react"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.mjs"],
  "exclude": ["dist", "node_modules"]
}
